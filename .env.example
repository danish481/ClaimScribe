# ── ClaimScribe AI — Environment Configuration ────────────────
# Copy this file to .env before running:
#   macOS/Linux:  cp .env.example .env
#   Windows:      copy .env.example .env
#
# All variables below are OPTIONAL — the app runs without any of them.
# Set GEMINI_API_KEY to unlock the full AI Assistant (free key available).

# ── AI Assistant (optional) ───────────────────────────────────
# Without this key the AI Assistant runs in demo mode with built-in responses.
# Get a free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

GEMINI_MODEL=gemini-2.5-flash

# ── Security ──────────────────────────────────────────────────
# Auto-generated on each start if not set.
# Set explicitly so encrypted files survive container restarts.
SECRET_KEY=change-me-in-production
ENCRYPTION_KEY=

# ── Pipeline ──────────────────────────────────────────────────
PIPELINE_SCHEDULE_MINUTES=30
PIPELINE_STORAGE_BACKEND=local    # local | s3 | gcs

# S3 (only needed if PIPELINE_STORAGE_BACKEND=s3)
# PIPELINE_S3_BUCKET=my-claims-bucket

# ── CORS (update when deploying to a real domain) ─────────────
CORS_ORIGINS=http://localhost:5174,http://localhost:5173,http://localhost:8001

# ── Service URLs (used by frontend — do not change for local Docker) ─
VITE_API_URL=http://localhost:8001
VITE_MLFLOW_URL=http://localhost:5001

# ── Environment ───────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO
